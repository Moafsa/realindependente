# Application Configuration
APP_NAME="Nexts Club Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# IMPORTANT: Never use default credentials in production!
# Generate strong, unique credentials for each environment
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting & Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
CACHE_STORE=database
CACHE_PREFIX=

# Redis Configuration (if using Redis)
REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# Configure your SMTP settings for email functionality
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using AWS services)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"

# Multi-tenancy Configuration
# Set your central domains for the SaaS platform
TENANCY_CENTRAL_DOMAINS=localhost,yourdomain.com
TENANCY_CENTRAL_DOMAIN=yourdomain.com

# API Keys - NEVER commit real keys to version control!
# OpenAI API Key for AI features
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Asaas API Key for payment processing
# Get your key at: https://www.asaas.com/
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# Wuzapi API Key for WhatsApp automation
# Get your key at: https://wuzapi.com/
WUZAPI_API_KEY=
WUZAPI_API_URL=

# Google Gemini API Key (alternative to OpenAI)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# AI Model Configuration
AI_MODEL=gpt-4

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# Email Configuration for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Security Settings
RATE_LIMITING_ENABLED=true
RATE_LIMITING_MAX_ATTEMPTS=60
RATE_LIMITING_DECAY_MINUTES=1

# Content Security Policy
CSP_ENABLED=true

# Security Headers
SECURITY_HEADERS_ENABLED=true

# Security Logging
SECURITY_LOG_CHANNEL=daily

# Session Security
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# API Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_PERIOD=1

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Token Expiration (in minutes)
TOKEN_EXPIRATION=60
REFRESH_TOKEN_EXPIRATION=10080

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Monitoring
MONITORING_ENABLED=true
ERROR_REPORTING_EMAIL=

# LGPD Compliance
DATA_RETENTION_DAYS=365
GDPR_COMPLIANCE=true

# Development Only - Remove in production!
# These should NEVER be used in production environments
# DEV_MODE=false
# DEBUG_BAR=false